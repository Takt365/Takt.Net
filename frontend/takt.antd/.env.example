# 复制本文件为 .env、.env.development 或 .env.production 后按需修改

# 应用标题
VITE_APP_TITLE=<your-app-title>

# 环境：development | production
VITE_APP_ENV=development

# API 基础路径（如 /api）
VITE_API_BASE_URL=<api-base-path>

# 请求超时（毫秒）
VITE_API_TIMEOUT=<timeout-ms>

# 开发：本地服务端口
VITE_DEV_SERVER_PORT=<port>

# 开发：本地服务主机
VITE_DEV_SERVER_HOST=<host>

# 开发：是否启用 HTTPS（true 时启用 mkcert；若在浏览器见 ERR_HTTP2_PROTOCOL_ERROR，请改为 false 使用 http:// 开发地址）
VITE_DEV_SERVER_HTTPS=<true|false>

# 开发/生产：后端 API 根地址（如 https://your-backend-host）
VITE_API_TARGET=<backend-api-url>

# 开发：是否启用 Mock
VITE_USE_MOCK=<true|false>

# 生产：是否生成 Source Map
VITE_BUILD_SOURCEMAP=<true|false>

# 生产：是否压缩构建产物
VITE_BUILD_COMPRESS=<true|false>
