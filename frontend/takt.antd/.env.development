# 开发环境配置
VITE_APP_ENV=development

# API 配置
VITE_API_BASE_URL=/api
VITE_API_TIMEOUT=30000

# 开发服务器：true=HTTPS+mkcert（请用 https://localhost:60081）；false=纯 HTTP（请用 http://localhost:60081，勿用 https 否则 ERR_SSL_PROTOCOL_ERROR）
# 若 true 时出现 ERR_HTTP2_PROTOCOL_ERROR，可改为 false 并只用 http:// 打开前端
VITE_DEV_SERVER_PORT=60081
VITE_DEV_SERVER_HOST=localhost
VITE_DEV_SERVER_HTTPS=true
VITE_API_TARGET=https://localhost:60071

# 是否开启 Mock
VITE_USE_MOCK=false
