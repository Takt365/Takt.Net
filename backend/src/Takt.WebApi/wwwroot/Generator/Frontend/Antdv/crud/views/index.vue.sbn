{{ has_get_list = false; has_get_options = false; has_create = false; has_update = false; has_delete = false; has_delete_batch = false; has_get_template = false; has_import_data = false; has_export_data = false; api_get_list = ""; api_get_options = ""; api_create = ""; api_update = ""; api_delete = ""; api_delete_batch = ""; api_get_template = ""; api_import_data = ""; api_export_data = ""; for a in table.controller_actions; if a.MethodName == "GetListAsync"; has_get_list = true; api_get_list = a.FrontendMethodName; end; if a.MethodName == "GetOptionsAsync"; has_get_options = true; api_get_options = a.FrontendMethodName; end; if a.MethodName == "CreateAsync"; has_create = true; api_create = a.FrontendMethodName; end; if a.MethodName == "UpdateAsync"; has_update = true; api_update = a.FrontendMethodName; end; if a.MethodName == "DeleteAsync"; has_delete = true; api_delete = a.FrontendMethodName; end; if a.MethodName == "DeleteBatchAsync"; has_delete = true; has_delete_batch = true; api_delete_batch = a.FrontendMethodName; end; if a.MethodName == "GetTemplateAsync"; has_get_template = true; api_get_template = a.FrontendMethodName; end; if a.MethodName == "ImportAsync"; has_import_data = true; api_import_data = a.FrontendMethodName; end; if a.MethodName == "ExportAsync"; has_export_data = true; api_export_data = a.FrontendMethodName; end; end }}

<template>
  <div class="{{ table.frontend_module_path | string.replace "/" "-" }}-{{ table.entity_name_kebab }}">
    <!-- 查询栏 -->
    <TaktQueryBar
      v-model="queryKeyword"
      :placeholder="searchPlaceholder"
      :loading="loading"
      @search="handleSearch"
      @reset="handleReset"
    />

    <!-- 工具栏 -->
    <TaktToolsBar
{{~ if has_create ~}}
      create-permission="{{ table.perms_prefix_canonical }}:create"
{{~ end ~}}
{{~ if has_update ~}}
      update-permission="{{ table.perms_prefix_canonical }}:update"
{{~ end ~}}
{{~ if has_delete ~}}
      delete-permission="{{ table.perms_prefix_canonical }}:delete"
{{~ end ~}}
{{~ if has_import_data ~}}
      import-permission="{{ table.perms_prefix_canonical }}:import"
{{~ end ~}}
{{~ if has_export_data ~}}
      export-permission="{{ table.perms_prefix_canonical }}:export"
{{~ end ~}}
      :show-create="{{ has_create }}"
      :show-update="{{ has_update }}"
      :show-delete="{{ has_delete }}"
      :show-import="{{ has_import_data }}"
      :show-export="{{ has_export_data }}"
      :show-expand="false"
      :show-advanced-query="true"
      :show-column-setting="true"
      :show-fullscreen="true"
      :show-refresh="true"
{{~ if has_create ~}}
      :create-disabled="false"
      :create-loading="loading"
{{~ end ~}}
{{~ if has_update ~}}
      :update-disabled="updateDisabled"
      :update-loading="loading"
{{~ end ~}}
{{~ if has_delete ~}}
      :delete-disabled="deleteDisabled"
      :delete-loading="loading"
{{~ end ~}}
      :refresh-loading="loading"
{{~ if has_create ~}}
      @create="handleCreate"
{{~ end ~}}
{{~ if has_update ~}}
      @update="handleUpdate"
{{~ end ~}}
{{~ if has_delete ~}}
      @delete="handleDelete"
{{~ end ~}}
{{~ if has_import_data ~}}
      @import="handleImport"
{{~ end ~}}
{{~ if has_export_data ~}}
      @export="handleExport"
{{~ end ~}}
      @advanced-query="handleAdvancedQuery"
      @column-setting="handleColumnSetting"
      @refresh="handleRefresh"
    />

    <!-- 表格 -->
    <TaktSingleTable
      :columns="displayColumns"
      :data-source="dataSource"
      :loading="loading"
      :stripe="true"
      :row-key="get{{ table.entity_name_pascal }}Id"
      :row-selection="rowSelection"
      :custom-row="onClickRow"
      :large-screen-column-count="{{ table.front_form_layout == 12 ? 5 : 9 }}"
      :small-screen-column-count="{{ table.front_form_layout == 12 ? 3 : 5 }}"
      @change="handleTableChange"
      @resize-column="handleResizeColumn"
    />

    <!-- 分页组件 -->
    <TaktPagination
      v-model:current="currentPage"
      v-model:page-size="pageSize"
      :total="total"
      @change="handlePaginationChange"
      @show-size-change="handlePaginationSizeChange"
    />

{{~ if has_create || has_update ~}}
    <!-- 新增/编辑对话框 -->
    <TaktModal
      v-model:open="formVisible"
      :title="formTitle"
      width="50%"
      wrap-class-name="takt-form-modal-resizable"
      :confirm-loading="formLoading"
      @ok="handleFormSubmit"
      @cancel="handleFormCancel"
    >
      <{{ table.entity_name_pascal }}Form
        ref="formRef"
        :form-data="formData"
        :loading="formLoading"
      />
    </TaktModal>
{{~ end ~}}

    <!-- 高级查询抽屉 -->
    <TaktQueryDrawer
      v-model:open="advancedQueryVisible"
      :form-model="advancedQueryForm"
      @submit="handleAdvancedQuerySubmit"
      @reset="handleAdvancedQueryReset"
    >
{{~ for col in columns ~}}
{{~ if col.is_query == 1 ~}}
      <a-form-item :label="t('entity.{{ table.entity_name_camel }}.{{ col.ts_column_name | string.downcase }}')">
{{~ if col.html_type == "select" && col.dict_type ~}}
        <TaktSelect
          v-model:value="advancedQueryForm.{{ col.ts_column_name }}"
          dict-type="{{ col.dict_type }}"
          :placeholder="t('common.form.placeholder.select', { field: t('entity.{{ table.entity_name_camel }}.{{ col.ts_column_name | string.downcase }}') })"
          allow-clear
        />
{{ else }}
        <a-input
          v-model:value="advancedQueryForm.{{ col.ts_column_name }}"
          :placeholder="t('common.form.placeholder.required', { field: t('entity.{{ table.entity_name_camel }}.{{ col.ts_column_name | string.downcase }}') })"
        />
{{~ end ~}}
      </a-form-item>
{{~ end ~}}
{{~ end ~}}
    </TaktQueryDrawer>
{{~ if has_import_data && has_get_template ~}}

    <!-- 导入对话框 -->
    <TaktModal
      v-model:open="importVisible"
      :title="t('common.button.import') + t('entity.{{ table.entity_name_camel }}._self')"
      :width="600"
      :footer="null"
      :cancel-text="t('common.button.close')"
      @cancel="handleImportCancel"
    >
      <TaktImportFile
        file-type="xlsx"
        :sheet-name="excelNames.sheet"
        :template-file-name="excelNames.fileBase"
        :download-template="handleDownloadTemplate"
        :import-file="handleImportFile"
        :template-text="t('common.action.import.templatetext', { entity: t('entity.{{ table.entity_name_camel }}._self') })"
        :upload-text="t('common.action.import.uploadtext')"
        :hint="t('common.action.import.hint')"
        :max-size="10"
        :max-rows="1000"
        @success="handleImportSuccess"
      />
    </TaktModal>
{{~ end ~}}

    <!-- 列设置抽屉 -->
    <TaktColumnDrawer
      v-model:open="columnSettingVisible"
      :columns="columns"
      :checked-keys="visibleColumnKeys"
      :id-column-key="'{{ table.entity_name_camel }}Id'"
      :action-column-key="'action'"
      @update:checked-keys="handleColumnKeysChange"
      @reset="handleColumnSettingReset"
    />
  </div>
</template>

<script setup lang="ts">
/**
 * {{ table.comment }}管理页 · 列表、查询、增删改由 GenFunction/ControllerActions 驱动
 * @module views/{{ table.frontend_module_path }}/{{ table.entity_name_kebab }}
 */
import { ref, computed, onMounted } from 'vue'
import { message, Modal } from 'ant-design-vue'
import type { TableColumnsType } from 'ant-design-vue'
import { CreateActionColumn } from '@/components/business/takt-action-column/index'
import { mergeDefaultColumns } from '@/utils/table-columns'
import { useI18n } from 'vue-i18n'
{{~ if has_create || has_update ~}}
import {{ table.entity_name_pascal }}Form from './components/{{ table.entity_name_kebab }}-form.vue'
{{~ end ~}}
import { {{ api_import_count = 0 }}{{ if has_get_list; api_import_count = api_import_count + 1; end }}{{ if has_get_options; api_import_count = api_import_count + 1; end }}{{ if has_create; api_import_count = api_import_count + 1; end }}{{ if has_update; api_import_count = api_import_count + 1; end }}{{ if has_delete; api_import_count = api_import_count + 1; end }}{{ if has_delete_batch; api_import_count = api_import_count + 1; end }}{{ if has_get_template; api_import_count = api_import_count + 1; end }}{{ if has_import_data; api_import_count = api_import_count + 1; end }}{{ if has_export_data; api_import_count = api_import_count + 1; end }}{{ api_import_index = 0 }}{{ if has_get_list; api_import_index = api_import_index + 1; }}{{ api_get_list }}{{ if api_import_index < api_import_count }}, {{ end }}{{ end }}{{ if has_get_options; api_import_index = api_import_index + 1; }}{{ api_get_options }}{{ if api_import_index < api_import_count }}, {{ end }}{{ end }}{{ if has_create; api_import_index = api_import_index + 1; }}{{ api_create }}{{ if api_import_index < api_import_count }}, {{ end }}{{ end }}{{ if has_update; api_import_index = api_import_index + 1; }}{{ api_update }}{{ if api_import_index < api_import_count }}, {{ end }}{{ end }}{{ if has_delete; api_import_index = api_import_index + 1; }}{{ api_delete }}{{ if api_import_index < api_import_count }}, {{ end }}{{ end }}{{ if has_delete_batch; api_import_index = api_import_index + 1; }}{{ api_delete_batch }}{{ if api_import_index < api_import_count }}, {{ end }}{{ end }}{{ if has_get_template; api_import_index = api_import_index + 1; }}{{ api_get_template }}{{ if api_import_index < api_import_count }}, {{ end }}{{ end }}{{ if has_import_data; api_import_index = api_import_index + 1; }}{{ api_import_data }}{{ if api_import_index < api_import_count }}, {{ end }}{{ end }}{{ if has_export_data; api_import_index = api_import_index + 1; }}{{ api_export_data }}{{ if api_import_index < api_import_count }}, {{ end }}{{ end }} } from '@/api/{{ table.frontend_module_path }}/{{ table.entity_name_kebab }}'
import type { {{ type_count = 0 }}{{~ for cat in table.dto_category_descriptors ~}}{{~ if cat.Name != "TemplateDto" && cat.Name != "ImportDto" && cat.Name != "ExportDto" ~}}{{ type_count = type_count + 1 }}{{~ end ~}}{{~ end ~}}{{ type_index = 0 }}{{~ for cat in table.dto_category_descriptors ~}}{{~ if cat.Name != "TemplateDto" && cat.Name != "ImportDto" && cat.Name != "ExportDto" ~}}{{ type_index = type_index + 1 }}{{ cat.TsInterfaceName }}{{ if type_index < type_count }}, {{ end }}{{~ end ~}}{{~ end ~}} } from '@/types/{{ table.frontend_module_path }}/{{ table.entity_name_kebab }}'
import { logger } from '@/utils/logger'
{{~ if has_export_data ~}}
import { resolveExportDownloadFileName } from '@/utils/export-download-name'
{{~ end ~}}
{{~ if has_import_data || has_export_data ~}}
import { taktExcelEntityNames } from '@/utils/naming'
{{~ end ~}}
{{~ if has_update || has_delete ~}}
import { RiEditLine, RiDeleteBinLine } from '@remixicon/vue'
{{~ end ~}}

const { t } = useI18n()
{{~ if has_import_data || has_export_data ~}}
const excelNames = taktExcelEntityNames('{{ table.entity_class_name }}')
{{~ end ~}}
const searchPlaceholder = computed(
  () => t('common.form.placeholder.required', { field: t('entity.{{ table.entity_name_camel }}._self') }) + t('common.button.query')
)

/** 关键词（查询栏） */
const queryKeyword = ref('')
/** 列表/表单加载中 */
const loading = ref(false)
/** 表格数据源 */
const dataSource = ref<{{ table.entity_name_pascal }}[]>([])
/** 当前页码 */
const currentPage = ref(1)
/** 每页条数 */
const pageSize = ref(20)
/** 总记录数 */
const total = ref(0)
/** 当前选中行（单行） */
const selectedRow = ref<{{ table.entity_name_pascal }} | null>(null)
/** 当前选中行列表（多选） */
const selectedRows = ref<{{ table.entity_name_pascal }}[]>([])
/** 当前选中行主键列表 */
const selectedRowKeys = ref<(string | number)[]>([])
/** 表单弹窗是否显示 */
{{~ if has_create || has_update ~}}
const formVisible = ref(false)
/** 表单弹窗标题（新增/编辑） */
const formTitle = ref('')
/** 表单数据（新增为空对象，编辑为当前行） */
const formData = ref<Partial<{{ table.entity_name_pascal }}>>({})
/** 表单提交中 */
const formLoading = ref(false)
const formRef = ref()
{{~ end ~}}
/** 高级查询抽屉是否显示 */
const advancedQueryVisible = ref(false)
/** 高级查询表单模型（IsQuery 列） */
const advancedQueryForm = ref({
{{~ for col in columns ~}}
{{~ if col.is_query == 1 ~}}
  {{ col.ts_column_name }}: {{ if col.ts_data_type == "number" }}undefined as number | undefined{{ else }}''{{ end }},
{{~ end ~}}
{{~ end ~}}
})
/** 列设置抽屉是否显示 */
const columnSettingVisible = ref(false)
{{~ if has_import_data && has_get_template ~}}
/** 导入弹窗是否显示 */
const importVisible = ref(false)
{{~ end ~}}
/** 当前可见列 key 列表（列设置勾选） */
const visibleColumnKeys = ref<string[]>([])

/** 主键字段名（与 types 一致，用于 getXxxId / 提交） */
const entityIdName = '{{ table.entity_name_camel }}Id'
{{~ if has_update ~}}
const updateDisabled = computed(() => selectedRows.value.length !== 1)
{{~ end ~}}
{{~ if has_delete ~}}
const deleteDisabled = computed(() => selectedRows.value.length === 0)
{{~ end ~}}

onMounted(() => {
  loadData()
})

/** 表格列配置（ID + IsList 列 + 操作列）；用 computed 与 identity/user/index.vue 一致，列标题与操作列 label 随 locale 变化；列 key 与表单 label 同源 entity.{模块实体}.{字段小写} */
const columns = computed<TableColumnsType>(() => [
  {
    title: t('entity.{{ table.entity_name_camel }}.{{ (table.entity_name_camel + "Id") | string.downcase }}'),
    dataIndex: '{{ table.entity_name_camel }}Id',
    key: 'entity.{{ table.entity_name_camel }}.{{ (table.entity_name_camel + "Id") | string.downcase }}',
    width: 80,
    resizable: true,
    ellipsis: true,
    fixed: 'left',
    customRender: ({ record }: { record: any }) => get{{ table.entity_name_pascal }}Field(record, '{{ table.entity_name_camel }}Id') ?? ''
  },
{{~ for col in columns ~}}
{{~ if col.is_list == 1 ~}}
  {
    title: t('entity.{{ table.entity_name_camel }}.{{ col.ts_column_name | string.downcase }}'),
    dataIndex: '{{ col.ts_column_name }}',
    key: 'entity.{{ table.entity_name_camel }}.{{ col.ts_column_name | string.downcase }}',
    width: 120,
    resizable: true,
    ellipsis: true,
    customRender: ({ record }: { record: any }) => get{{ table.entity_name_pascal }}Field(record, '{{ col.ts_column_name }}') ?? ''
  },
{{~ end ~}}
{{~ end ~}}
  CreateActionColumn({
    actions: [
{{~ if has_update ~}}
      {
        key: 'update',
        label: t('common.button.edit'),
        shape: '{{ table.front_btn_style == 0 ? "plain" : "standard" }}',
        icon: RiEditLine,
        permission: '{{ table.perms_prefix_canonical }}:update',
        onClick: (record: {{ table.entity_name_pascal }}) => handleEdit(record)
      },
{{~ end ~}}
{{~ if has_delete ~}}
      {
        key: 'delete',
        label: t('common.button.delete'),
        shape: '{{ table.front_btn_style == 0 ? "plain" : "standard" }}',
        icon: RiDeleteBinLine,
        permission: '{{ table.perms_prefix_canonical }}:delete',
        onClick: (record: {{ table.entity_name_pascal }}) => handleDeleteOne(record)
      }
{{~ end ~}}
    ]
  })
])

/** 取当前行主键 ID（{{ table.entity_name_camel }}Id） */
const get{{ table.entity_name_pascal }}Id = (record: any): string => record?.[entityIdName] ?? ''
/** 取当前行指定字段值 */
const get{{ table.entity_name_pascal }}Field = (record: any, field: string): any => record?.[field]

/** 合并默认列（含审计列等） */
const mergedColumns = computed((): any => mergeDefaultColumns(columns.value as any, t, true))
/** 根据列设置过滤后的显示列 */
const displayColumns = computed(() => {
  const keys = visibleColumnKeys.value || []
  const merged = mergedColumns.value || []
  if (keys.length === 0) return columns.value
  const keysSet = new Set(keys.map((k: any) => String(k)))
  return merged.filter((col: any) => {
    const colKey = col.key || col.dataIndex || col.title
    return colKey && keysSet.has(String(colKey))
  })
})

/** 行选择配置（单选/多选联动 selectedRow、selectedRows） */
const rowSelection = computed(() => ({
  selectedRowKeys: selectedRowKeys.value,
  onChange: (keys: (string | number)[], rows: {{ table.entity_name_pascal }}[]) => {
    selectedRowKeys.value = keys
    selectedRows.value = rows
    selectedRow.value = rows.length === 1 ? (rows[0] ?? null) : null
  },
  onSelect: (record: {{ table.entity_name_pascal }}, selected: boolean) => {
    if (selected) {
      selectedRow.value = record
    } else if (get{{ table.entity_name_pascal }}Id(selectedRow.value) === get{{ table.entity_name_pascal }}Id(record)) {
      selectedRow.value = null
    }
  },
  onSelectAll: (selected: boolean, selectedRowsData: {{ table.entity_name_pascal }}[]) => {
    if (selected) {
      selectedRow.value = selectedRowsData.length === 1 ? (selectedRowsData[0] ?? null) : null
    } else {
      selectedRow.value = null
    }
  }
}))

/** 行点击处理：点击行切换选中/取消；同步 selectedRowKeys、selectedRows、selectedRow，并调用 rowSelection.onChange 以同步表格复选框（与 identity/user 列表页 custom-row 标准一致） */
const onClickRow = (record: {{ table.entity_name_pascal }}) => ({
  onClick: () => {
    const key = get{{ table.entity_name_pascal }}Id(record)
    const index = selectedRowKeys.value.indexOf(key)
    if (index > -1) {
      selectedRowKeys.value.splice(index, 1)
    } else {
      selectedRowKeys.value.push(key)
    }
    selectedRows.value = dataSource.value.filter(item =>
      selectedRowKeys.value.includes(get{{ table.entity_name_pascal }}Id(item))
    )
    selectedRow.value = selectedRowKeys.value.length === 1 ? (selectedRows.value[0] ?? null) : null
    if (rowSelection.value.onChange) {
      rowSelection.value.onChange(selectedRowKeys.value, selectedRows.value)
    }
  }
})

/** 加载列表数据（有列表接口时请求分页，否则清空） */
async function loadData() {
  loading.value = true
  try {
{{~ if has_get_list ~}}
    const kw = (queryKeyword.value ?? '').trim()
    const params: {{ table.entity_name_pascal }}Query = {
      pageIndex: currentPage.value,
      pageSize: pageSize.value,
      ...advancedQueryForm.value
    }
    if (kw.length > 0) {
      params.KeyWords = kw
    }
    const res = await {{ api_get_list }}(params)
    dataSource.value = res.data ?? []
    total.value = res.total ?? 0
{{~ else ~}}
    dataSource.value = []
    total.value = 0
{{~ end ~}}
  } catch (error: any) {
    logger.error('[{{ table.entity_name_pascal }} Management] 加载数据失败:', error)
    message.error(error?.message || t('common.msg.loadfail'))
    dataSource.value = []
    total.value = 0
  } finally {
    loading.value = false
  }
}

/** 查询：重置页码并重新加载 */
function handleSearch() {
  currentPage.value = 1
  loadData()
}

/** 重置：清空关键词与高级查询条件并重新加载 */
function handleReset() {
  queryKeyword.value = ''
  advancedQueryForm.value = {
{{~ for col in columns ~}}
{{~ if col.is_query == 1 ~}}
    {{ col.ts_column_name }}: {{ if col.ts_data_type == "number" }}undefined as number | undefined{{ else }}''{{ end }},
{{~ end ~}}
{{~ end ~}}
  }
  currentPage.value = 1
  loadData()
}

{{~ if has_create ~}}
/** 打开新增表单 */
function handleCreate() {
  formTitle.value = t('common.button.create') + t('entity.{{ table.entity_name_camel }}._self')
  formData.value = {}
  formVisible.value = true
}
{{~ end ~}}

{{~ if has_update ~}}
/** 打开编辑表单并回填当前行 */
function handleEdit(record: {{ table.entity_name_pascal }}) {
  formTitle.value = t('common.button.edit') + t('entity.{{ table.entity_name_camel }}._self')
  formData.value = { ...record }
  formVisible.value = true
}

/** 编辑当前选中行 */
function handleUpdate() {
  if (selectedRow.value) {
    handleEdit(selectedRow.value)
  } else {
    message.warning(t('common.action.warnselecttoaction', { action: t('common.button.edit'), entity: t('entity.{{ table.entity_name_camel }}._self') }))
  }
}
{{~ end ~}}

{{~ if has_create || has_update ~}}
/** 提交表单：有 ID 则更新，否则新增 */
async function handleFormSubmit() {
  const ref = formRef.value
  if (!ref?.validate) return
  try {
    await ref.validate()
  } catch {
    return
  }
  formLoading.value = true
  try {
    const id = (formData.value as any)?.[entityIdName]
    if (id) {
{{~ if has_update ~}}
      await {{ api_update }}(id, formData.value as any)
      message.success(t('common.msg.updatesuccess'))
{{~ end ~}}
    } else {
{{~ if has_create ~}}
      await {{ api_create }}(formData.value as any)
      message.success(t('common.msg.createsuccess'))
{{~ end ~}}
    }
    formVisible.value = false
    loadData()
  } finally {
    formLoading.value = false
  }
}

/** 关闭表单弹窗 */
function handleFormCancel() {
  formVisible.value = false
}
{{~ end ~}}

{{~ if has_import_data && has_get_template ~}}
/** 打开导入弹窗 */
function handleImport() {
  importVisible.value = true
}

/** 下载导入模板 */
async function handleDownloadTemplate(sheetName?: string, fileName?: string): Promise<Blob> {
  const res = await {{ api_get_template }}(sheetName, fileName)
  return (res as any)?.data ?? res
}

/** 执行导入 */
async function handleImportFile(file: File, sheetName?: string): Promise<{ success: number; fail: number; errors: string[] }> {
  return await {{ api_import_data }}(file, sheetName)
}

/** 导入成功回调 */
function handleImportSuccess(result: { success: number; fail: number; errors: string[] }) {
  loadData()
  if (result.fail === 0) setTimeout(() => { importVisible.value = false }, 2000)
}

/** 关闭导入弹窗 */
function handleImportCancel() {
  importVisible.value = false
}
{{~ end ~}}

{{~ if has_export_data ~}}
/** 导出数据 */
async function handleExport() {
  try {
    loading.value = true
    const kw = (queryKeyword.value ?? '').trim()
    const exportQuery: {{ table.entity_name_pascal }}Query = {
      pageIndex: currentPage.value,
      pageSize: pageSize.value,
      ...advancedQueryForm.value
    }
    if (kw.length > 0) {
      exportQuery.KeyWords = kw
    }
    const exportMeta = await {{ api_export_data }}(exportQuery, excelNames.sheet, excelNames.fileBase)
    const ts = new Date()
    const pad = (n: number, w = 2) => String(n).padStart(w, '0')
    const fallbackBase = `${excelNames.fileBase}_${ts.getFullYear()}${pad(ts.getMonth() + 1)}${pad(ts.getDate())}${pad(ts.getHours())}${pad(ts.getMinutes())}${pad(ts.getSeconds())}`
    const fileName = resolveExportDownloadFileName({
      contentDisposition: exportMeta.contentDisposition ?? null,
      contentType: exportMeta.contentType ?? null,
      fallbackBase
    })
    const url = window.URL.createObjectURL(exportMeta.blob)
    const link = document.createElement('a')
    link.href = url
    link.download = fileName
    link.style.display = 'none'
    document.body.appendChild(link)
    link.click()
    document.body.removeChild(link)
    setTimeout(() => window.URL.revokeObjectURL(url), 100)
    message.success(t('common.msg.exportsuccess'))
  } catch (error: any) {
    logger.error('[{{ table.entity_name_pascal }} Management] 导出失败:', error)
    message.error(error?.message || t('common.msg.exportfail'))
  } finally {
    loading.value = false
  }
}
{{~ end ~}}

{{~ if has_delete ~}}
/** 单条删除（有 delete 时确认后调用接口） */
async function handleDeleteOne(record: {{ table.entity_name_pascal }}) {
  Modal.confirm({
    title: t('common.action.confirmdelete'),
    content: t('common.confirm.deleteentity', { entity: t('entity.{{ table.entity_name_camel }}._self'), name: t('common.action.thistarget', { target: t('entity.{{ table.entity_name_camel }}._self') }) }),
    okText: t('common.button.delete'),
    cancelText: t('common.button.cancel'),
    onOk: async () => {
      await {{ api_delete }}((record as any)[entityIdName])
      message.success(t('common.msg.deletesuccess'))
      loadData()
    }
  })
}
{{~ end ~}}

{{~ if has_delete_batch ~}}
/** 批量删除（有批量删除接口时确认后调用） */
async function handleDelete() {
  if (selectedRows.value.length === 0) {
    message.warning(t('common.action.warnselecttoaction', { action: t('common.button.delete'), entity: t('entity.{{ table.entity_name_camel }}._self') }))
    return
  }
  Modal.confirm({
    title: t('common.action.confirmdelete'),
    content: t('common.confirm.deletecountentity', { entity: t('entity.{{ table.entity_name_camel }}._self'), count: selectedRows.value.length }),
    okText: t('common.button.delete'),
    cancelText: t('common.button.cancel'),
    onOk: async () => {
      const ids = selectedRows.value.map((r: any) => r[entityIdName]).filter(Boolean)
      await {{ api_delete_batch }}(ids)
      message.success(t('common.msg.deletesuccess'))
      loadData()
    }
  })
}
{{~ end ~}}

/** 打开高级查询抽屉 */
function handleAdvancedQuery() {
  advancedQueryVisible.value = true
}

/** 高级查询提交：关闭抽屉并重新加载 */
function handleAdvancedQuerySubmit() {
  advancedQueryVisible.value = false
  currentPage.value = 1
  loadData()
}

/** 高级查询重置：清空表单 */
function handleAdvancedQueryReset() {
  advancedQueryForm.value = {
{{~ for col in columns ~}}
{{~ if col.is_query == 1 ~}}
    {{ col.ts_column_name }}: {{ if col.ts_data_type == "number" }}undefined as number | undefined{{ else }}''{{ end }},
{{~ end ~}}
{{~ end ~}}
  }
}

/** 打开列设置抽屉 */
function handleColumnSetting() {
  columnSettingVisible.value = true
}

/** 列显示勾选变化 */
function handleColumnKeysChange(keys: string[]) {
  visibleColumnKeys.value = keys
}

/** 列设置重置为全部显示 */
function handleColumnSettingReset() {
  visibleColumnKeys.value = columns.value.map((c: any) => c.key || c.dataIndex).filter(Boolean)
}

/** 刷新列表 */
function handleRefresh() {
  loadData()
}

/** 表格 change 占位 */
function handleTableChange() {}
/** 列宽拖拽占位 */
function handleResizeColumn() {}
/** 分页页码变化 */
function handlePaginationChange(page: number) {
  currentPage.value = page
  loadData()
}
/** 分页每页条数变化 */
function handlePaginationSizeChange(_current: number, size: number) {
  pageSize.value = size
  currentPage.value = 1
  loadData()
}
</script>

<style scoped lang="less">
.{{ table.frontend_module_path | string.replace "/" "-" }}-{{ table.entity_name_kebab }} {
  padding: 0;
}
</style>
