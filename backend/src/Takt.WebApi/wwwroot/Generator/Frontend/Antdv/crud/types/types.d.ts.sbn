import type { TaktEntityBase, TaktPagedQuery } from '@/types/common'

{{ entity_id_ts = table.entity_name_camel + "Id" }}
{{ entity_id_pascal = table.entity_name_pascal + "Id" }}
{{~ for cat in table.dto_category_descriptors ~}}
{{~ if cat.Name != "TemplateDto" && cat.Name != "ImportDto" && cat.Name != "ExportDto" ~}}
{{ cat_name_lower = string.downcase cat.Name }}
{{ body_kind_raw = cat.BodyKind }}
{{~ if body_kind_raw == null || body_kind_raw == "" ~}}
{{ body_kind_raw = cat.body_kind }}
{{~ end ~}}
{{~ if body_kind_raw == null || body_kind_raw == "" ~}}
{{ body_kind_raw = "NoId" }}
{{~ end ~}}
{{ body_kind = string.downcase (string.strip body_kind_raw) }}
/**
 * {{ table.comment }}{{ cat.Name }}类型（对应后端 {{ table.dto_namespace }}.{{ table.entity_class_name }}{{ cat.Name }}）
 */
export interface {{ cat.TsInterfaceName }}{{ if cat.TsExtendsName != null && cat.TsExtendsName != "" }} extends {{ cat.TsExtendsName }}{{ end }} {
{{~ if cat_name_lower == "dto" || body_kind == "full" ~}}
  /** {{ table.comment }}ID（对应后端 {{ entity_id_pascal }}，序列化为string以避免Javascript精度问题） */
  {{ entity_id_ts }}: string
{{~ for col in columns ~}}
{{~ if col.csharp_column_name != "Id" ~}}
  /** {{ col.comment }} */
  {{ col.ts_column_name }}{{ if col.is_required == 0 }}?{{ end }}: {{ col.ts_data_type }}
{{~ end ~}}
{{~ end ~}}
{{~ end ~}}
{{~ if cat_name_lower == "querydto" || body_kind == "query" ~}}
  /** 关键词（模糊查询） */
  keyWords?: string
{{~ for col in columns ~}}
{{~ if col.is_query == 1 ~}}
  /** {{ col.comment }} */
  {{ col.ts_column_name }}?: {{ col.ts_data_type }}
{{~ end ~}}
{{~ end ~}}
{{~ end ~}}
{{~ if cat_name_lower == "createdto" || (body_kind == "noid" && cat_name_lower == "createdto") ~}}
{{~ for col in columns ~}}
{{~ if col.is_create == 1 ~}}
  /** {{ col.comment }} */
  {{ col.ts_column_name }}{{ if col.is_required == 0 }}?{{ end }}: {{ col.ts_data_type }}
{{~ end ~}}
{{~ end ~}}
{{~ end ~}}
{{~ if cat_name_lower == "updatedto" || body_kind == "onlyid" ~}}
  /** {{ table.comment }}ID（对应后端 {{ entity_id_pascal }}，序列化为string以避免Javascript精度问题） */
  {{ entity_id_ts }}: string
{{~ end ~}}
}
{{~ end ~}}
{{~ end ~}}
