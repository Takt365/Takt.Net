    /// <summary>
    /// 获取{{ table.comment }}选项列表（用于下拉框等）
    /// </summary>
    /// <returns>选项列表</returns>
    public async Task<List<TaktSelectOption>> Get{{ table.entity_name_pascal }}OptionsAsync()
    {
        var list = await _repository.FindAsync(x => x.IsDeleted == 0);
        return list
            .OrderBy(x => x.Id)
            .Select(x => new TaktSelectOption
            {
{{~ if option_label_col != "" ~}}
                DictLabel = (Convert.ToString(x.{{ option_label_col }}) ?? string.Empty).Trim(),
{{~ else ~}}
                DictLabel = x.Id.ToString(),
{{~ end ~}}
                DictValue = x.Id,
                OrderNum = 0
            })
            .ToList();
    }

