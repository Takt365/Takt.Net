    /// <summary>
    /// 构建查询表达式
    /// </summary>
    /// <param name="queryDto">查询DTO</param>
    /// <returns>查询表达式</returns>
    private static System.Linq.Expressions.Expression<Func<{{ table.entity_class_name }}, bool>> QueryExpression({{ table.entity_class_name }}QueryDto queryDto)
    {
        var exp = Expressionable.Create<{{ table.entity_class_name }}>();

        // 关键词查询（在可查询的字符串字段中模糊匹配）
        if (!string.IsNullOrEmpty(queryDto?.KeyWords))
        {
            exp = exp.And(x =>
{{ first_keyword = true }}
{{~ for col in columns ~}}
{{~ if col.csharp_column_name != "Id" && col.is_query == 1 && (col.csharp_data_type == "string" || col.csharp_data_type == "String") ~}}
{{~ if first_keyword ~}}{{ first_keyword = false }}                x.{{ col.csharp_column_name }}.Contains(queryDto.KeyWords)
{{~ else ~}}                || x.{{ col.csharp_column_name }}.Contains(queryDto.KeyWords)
{{~ end ~}}
{{~ end ~}}
{{~ end ~}}
{{ if first_keyword }}                x.Remark != null && x.Remark.Contains(queryDto.KeyWords){{ end }}
            );
        }

{{~ for col in columns ~}}
{{~ if col.csharp_column_name != "Id" && col.is_query == 1 ~}}
{{~ if col.csharp_data_type == "string" || col.csharp_data_type == "String" ~}}
        // {{ col.comment }}
        exp = exp.AndIF(!string.IsNullOrEmpty(queryDto?.{{ col.csharp_column_name }}), x => x.{{ col.csharp_column_name }}.Contains(queryDto!.{{ col.csharp_column_name }}!));
{{~ else if col.csharp_data_type | string.downcase != "bool" && col.is_required == 0 ~}}
        // {{ col.comment }}
        exp = exp.AndIF(queryDto?.{{ col.csharp_column_name }}.HasValue == true, x => x.{{ col.csharp_column_name }} == queryDto!.{{ col.csharp_column_name }}!.Value);
{{~ end ~}}
{{~ end ~}}
{{~ end ~}}

        return exp.ToExpression();
    }
{{ end }}
