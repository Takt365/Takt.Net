    /// <summary>
    /// 获取导入模板
    /// </summary>
    /// <param name="sheetName">工作表名称</param>
    /// <param name="fileName">文件名</param>
    /// <returns>Excel模板文件信息（文件名和内容）</returns>
    public async Task<(string fileName, byte[] content)> GetTemplateAsync(string? sheetName, string? fileName)
    {
        return await TaktExcelHelper.GenerateTemplateAsync<{{ table.entity_class_name }}TemplateDto>(
            sheetName: string.IsNullOrWhiteSpace(sheetName) ? "{{ table.comment }}导入模板" : sheetName,
            fileName: string.IsNullOrWhiteSpace(fileName) ? "{{ table.comment }}导入模板" : fileName
        );
    }
{{~ end ~}}

{{~ else if type == "ImportDto" ~}}
{{~ if table.gen_import == 1 ~}}
    /// <summary>
    /// 导入{{ table.comment }}
    /// </summary>
    /// <param name="fileStream">Excel文件流</param>
    /// <param name="sheetName">工作表名称</param>
    /// <returns>导入结果（成功数量、失败数量、错误信息列表）</returns>
    public async Task<(int success, int fail, List<string> errors)> ImportAsync(Stream fileStream, string? sheetName)
    {
        var errors = new List<string>();
        int success = 0;
        int fail = 0;
        var importData = await TaktExcelHelper.ImportAsync<{{ table.entity_class_name }}ImportDto>(fileStream, string.IsNullOrWhiteSpace(sheetName) ? "{{ table.comment }}导入模板" : sheetName);
        if (importData == null || importData.Count == 0)
        {
            errors.Add("Excel文件中没有数据");
            return (0, 0, errors);
        }
        foreach (var item in importData)
        {
            try
            {
                var e = item.Adapt<{{ table.entity_class_name }}>();
                await _repository.CreateAsync(e);
                success++;
            }
            catch (Exception ex)
            {
                fail++;
                errors.Add(ex.Message);
            }
        }
        return (success, fail, errors);
    }
{{~ end ~}}

{{~ else if type == "ExportDto" ~}}
{{~ if table.gen_export == 1 ~}}
    /// <summary>
    /// 导出{{ table.comment }}
    /// </summary>
    /// <param name="query">{{ table.comment }}查询DTO（包含查询条件）</param>
    /// <param name="sheetName">工作表名称</param>
    /// <param name="fileName">文件名</param>
    /// <returns>Excel文件信息（文件名和内容）</returns>
    public async Task<(string fileName, byte[] content)> ExportAsync({{ table.entity_class_name }}QueryDto query, string? sheetName, string? fileName)
    {
        var predicate = QueryExpression(query);
        var data = predicate != null ? await _repository.FindAsync(predicate) : await _repository.GetAllAsync();
        var dtos = data?.Adapt<List<{{ table.entity_class_name }}ExportDto>>() ?? new List<{{ table.entity_class_name }}ExportDto>();
        return await TaktExcelHelper.ExportAsync(dtos,
            string.IsNullOrWhiteSpace(sheetName) ? "{{ table.comment }}数据" : sheetName,
            string.IsNullOrWhiteSpace(fileName) ? "{{ table.comment }}导出" : fileName);
    }
{{~ end ~}}
{{~ end ~}}
{{~ end ~}}
{{~ if table.gen_query == 1 ~}}

    /// <summary>
    /// 构建查询表达式（供 GetListAsync / ExportAsync 使用，放在类末尾）
    /// </summary>
    /// <param name="queryDto">查询DTO，可为 null</param>
    /// <returns>查询表达式</returns>
    private static Expression<Func<{{ table.entity_class_name }}, bool>> QueryExpression({{ table.entity_class_name }}QueryDto? queryDto)
    {
        var exp = Expressionable.Create<{{ table.entity_class_name }}>();
        if (queryDto == null)
            return exp.ToExpression();

        // 关键词查询（在多个字段中模糊查询）
{{~ kw_cols = array.new ~}}
{{~ for col in columns ~}}
{{~ if col.is_query == 0 && (col.query_type == "like" || col.query_type == "Like" || col.query_type == "LIKE") && (col.csharp_data_type == "string" || col.csharp_data_type == "String") ~}}
{{~ kw_cols = array.add kw_cols col ~}}
{{~ end ~}}
{{~ end ~}}
        if (!string.IsNullOrEmpty(queryDto?.KeyWords))
        {
{{~ if kw_cols.size > 0 ~}}
            exp = exp.And(x => {{ for col in kw_cols ~}}{{ if for.index > 0 }} || {{ end }}(x.{{ col.csharp_column_name }} != null && x.{{ col.csharp_column_name }}.Contains(queryDto.KeyWords)){{ end ~}});
{{~ end ~}}
        }

        // 单字段查询
{{~ for col in columns ~}}
{{~ if col.is_query == 0 ~}}
{{~ qt_like = col.query_type == "like" || col.query_type == "Like" || col.query_type == "LIKE" ~}}
{{~ qt_eq = col.query_type == "eq" || col.query_type == "Eq" || col.query_type == "EQ" ~}}
{{~ qt_ne = col.query_type == "ne" || col.query_type == "Ne" || col.query_type == "NE" ~}}
{{~ qt_gt = col.query_type == "gt" || col.query_type == "Gt" || col.query_type == "GT" ~}}
{{~ qt_lt = col.query_type == "lt" || col.query_type == "Lt" || col.query_type == "LT" ~}}
{{~ is_str = col.csharp_data_type == "string" || col.csharp_data_type == "String" ~}}
{{~ is_nullable_val = col.is_required == 1 && (col.csharp_data_type != "string" && col.csharp_data_type != "String") ~}}
{{~ if qt_like && is_str ~}}
        exp = exp.AndIF(!string.IsNullOrEmpty(queryDto?.{{ col.csharp_column_name }}), x => x.{{ col.csharp_column_name }} != null && x.{{ col.csharp_column_name }}.Contains(queryDto!.{{ col.csharp_column_name }}!));
{{~ else if qt_eq ~}}
{{~ if is_str ~}}
        exp = exp.AndIF(!string.IsNullOrEmpty(queryDto?.{{ col.csharp_column_name }}), x => x.{{ col.csharp_column_name }} == queryDto!.{{ col.csharp_column_name }}!);
{{~ else if is_nullable_val ~}}
        exp = exp.AndIF(queryDto?.{{ col.csharp_column_name }}.HasValue == true, x => x.{{ col.csharp_column_name }} == queryDto!.{{ col.csharp_column_name }}!.Value);
{{~ else ~}}
        exp = exp.AndIF(queryDto != null, x => x.{{ col.csharp_column_name }} == queryDto!.{{ col.csharp_column_name }});
{{~ end ~}}
{{~ else if qt_ne ~}}
{{~ if is_str ~}}
        exp = exp.AndIF(!string.IsNullOrEmpty(queryDto?.{{ col.csharp_column_name }}), x => x.{{ col.csharp_column_name }} != queryDto!.{{ col.csharp_column_name }}!);
{{~ else if is_nullable_val ~}}
        exp = exp.AndIF(queryDto?.{{ col.csharp_column_name }}.HasValue == true, x => x.{{ col.csharp_column_name }} != queryDto!.{{ col.csharp_column_name }}!.Value);
{{~ else ~}}
        exp = exp.AndIF(queryDto != null, x => x.{{ col.csharp_column_name }} != queryDto!.{{ col.csharp_column_name }});
{{~ end ~}}
{{~ else if qt_gt ~}}
{{~ if is_nullable_val ~}}
        exp = exp.AndIF(queryDto?.{{ col.csharp_column_name }}.HasValue == true, x => x.{{ col.csharp_column_name }} > queryDto!.{{ col.csharp_column_name }}!.Value);
{{~ else ~}}
        exp = exp.AndIF(queryDto != null, x => x.{{ col.csharp_column_name }} > queryDto!.{{ col.csharp_column_name }});
{{~ end ~}}
{{~ else if qt_lt ~}}
{{~ if is_nullable_val ~}}
        exp = exp.AndIF(queryDto?.{{ col.csharp_column_name }}.HasValue == true, x => x.{{ col.csharp_column_name }} < queryDto!.{{ col.csharp_column_name }}!.Value);
{{~ else ~}}
        exp = exp.AndIF(queryDto != null, x => x.{{ col.csharp_column_name }} < queryDto!.{{ col.csharp_column_name }});
{{~ end ~}}
{{~ end ~}}
{{~ end ~}}
{{~ end ~}}
        return exp.ToExpression();
    }
{{~ end ~}}
}
