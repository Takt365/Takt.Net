    /// <param name="id">{{ table.comment }}ID</param>
    /// <returns>{{ table.comment }}DTO</returns>
    public async Task<{{ table.entity_class_name }}Dto?> GetByIdAsync(long id)
    {
        var entity = await _repository.GetByIdAsync(id);
        return entity?.Adapt<{{ table.entity_class_name }}Dto>();
    }

    /// <summary>
    /// 获取{{ table.comment }}选项列表（用于下拉框等）
    /// </summary>
    /// <returns>{{ table.comment }}选项列表</returns>
    public async Task<List<TaktSelectOption>> GetOptionsAsync()
    {
{{~ opt_label_col = null ~}}
{{~ opt_label_fallback = null ~}}
{{~ for col in columns ~}}
{{~ col_name = col.csharp_column_name ~}}
{{~ col_type = col.csharp_data_type ~}}
{{~ skip_id = col_name == "Id" ~}}
{{~ is_string = col_type == "string" || col_type == "String" ~}}
{{~ if !skip_id && is_string ~}}
{{~ has_name = col_name == "Name" || col_name == "name" || col_name == "DisplayName" || col_name == "EntityName" ~}}
{{~ has_code = col_name == "Code" || col_name == "code" ~}}
{{~ name_or_code = has_name || has_code ~}}
{{~ if name_or_code && opt_label_col == null ~}}
{{~ opt_label_col = col ~}}
{{~ else if opt_label_fallback == null ~}}
{{~ opt_label_fallback = col ~}}
{{~ end ~}}
{{~ end ~}}
{{~ end ~}}
{{~ opt_label_col = opt_label_col || opt_label_fallback ~}}
{{~ opt_label_name = "" ~}}
{{~ if opt_label_col != null ~}}
{{~ opt_label_name = opt_label_col.csharp_column_name ?? "" ~}}
{{~ end ~}}
{{~ if opt_label_col != null && opt_label_name != "" ~}}
        var list = await _repository.FindAsync(x => x.IsDeleted == 0);
        return list
            .OrderBy(x => x.CreateTime)
            .Select(x => new TaktSelectOption
            {
                DictLabel = (x.{{ opt_label_name }} ?? "").ToString(),
                DictValue = x.Id,
                OrderNum = 0
            })
            .ToList();
{{~ else ~}}
        var list = await _repository.FindAsync(x => x.IsDeleted == 0);
        return list
            .OrderBy(x => x.CreateTime)
            .Select(x => new TaktSelectOption
            {
                DictLabel = x.Id.ToString(),
                DictValue = x.Id,
                OrderNum = 0
            })
            .ToList();
{{~ end ~}}
    }
