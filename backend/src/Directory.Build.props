<Project>
  <PropertyGroup>
    <!-- 目标框架 -->
    <TargetFramework>net9.0</TargetFramework>
    <!-- 可空引用类型 -->
    <Nullable>enable</Nullable>
    <!-- 隐式 using -->
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- 程序版本号：与 version.json 同步，格式 0.1.年.月+序号（月 01~12），运行 node scripts/bump-version.mjs 自增 -->
    <Version>0.1.2026.02004</Version>
    <AssemblyVersion>0.1.2026.02004</AssemblyVersion>
    <FileVersion>0.1.2026.02004</FileVersion>
    <AssemblyInformationalVersion>0.1.2026.02004</AssemblyInformationalVersion>
  </PropertyGroup>
</Project>
